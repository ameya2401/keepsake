# ============================================================
# Keepsake — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# Supabase (required)
# Get from: https://supabase.com → Your Project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Groq — Text generation and vision (required)
# Get from: https://console.groq.com
# Free tier: 100 requests/minute — more than enough
VITE_GROQ_API_KEY=gsk_your-groq-api-key

# Google Gemini — Embeddings only (required for semantic search)
# Get from: https://aistudio.google.com
# Free tier: 1,500 requests/day — sufficient for normal usage
VITE_GEMINI_API_KEY=AIzaSy_your-gemini-api-key
